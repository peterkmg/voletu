# ==========================
# Voletu Server Configuration
# ==========================
# Copy this file to `.env` and fill in your values.
# All variables below are required unless marked optional.

# ── API binding ──────────────────────────────────────
API_HOST=0.0.0.0          # Listen address (0.0.0.0 = all interfaces)
API_PORT=3000              # Listen port (1–65535)

# ── JWT configuration ────────────────────────────────
JWT_EXPIRATION_SECONDS=28800          # Access token lifetime (8 hours)
JWT_REFRESH_EXPIRATION_SECONDS=604800 # Refresh token lifetime (7 days)

# ── Database backend ─────────────────────────────────
# Supported: sqlite | postgres | mysql
DB_TYPE=sqlite

# Database password (always required, used for encryption key derivation)
DB_PASSWORD=replace-with-secure-password

# ── SQLite (required when DB_TYPE=sqlite) ────────────
DB_FILE=./voletu_server.db

# ── Postgres / MySQL (required when DB_TYPE=postgres or mysql) ──
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=voletu
# DB_USER=voletu

# ── CORS (optional) ───────────────────────────────────
# Comma-separated list of allowed origins. If empty, defaults to
# tauri://localhost and http://localhost.
# CORS_ALLOWED_ORIGINS=https://app.example.com,http://localhost:5173

# ── Logging ──────────────────────────────────────────
LOG_FILTER=info,voletu_core=debug,voletu_server=debug
LOG_FILE=./logs/voletu-server.log
