API_HOST=localhost
API_PORT=8080

JWT_SECRET=replace_with_secure_secret
JWT_EXPIRATION_SECONDS=28800
JWT_REFRESH_EXPIRATION_SECONDS=604800

# Database configuration
DB_TYPE=sqlite # sqlite | postgres | mysql
DB_PASSWORD=replace_with_database_password

# SQLite only
DB_SQLITE_FILE=./voletu_server.db

# Postgres/MySQL only
DB_HOST=127.0.0.1
DB_PORT=5432 # 3306 for MySQL
DB_NAME=voletu
DB_USER=voletu
