{
  "name": "voletu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter @voletu/frontend dev",
    "dev:server": "cargo run --package voletu-server",
    "dev:tauri": "pnpm tauri dev",
    "build:frontend": "pnpm --filter @voletu/frontend build",
    "build:server": "cargo build --package voletu-server --release",
    "build:tauri": "pnpm tauri build",
    "tauri": "tauri",
    "check": "cargo check --workspace"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@tauri-apps/cli": "^2.10.0",
    "eslint": "^9.39.3",
    "eslint-plugin-format": "^1.4.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "prettier": "^3.8.1"
  }
}
