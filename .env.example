# ==========================
# Voletu Server Configuration
# ==========================
# All variables below are required. Missing values will prevent server startup.

# API binding
API_HOST=0.0.0.0
API_PORT=3000

# JWT configuration
JWT_EXPIRATION_SECONDS=28800
JWT_REFRESH_EXPIRATION_SECONDS=604800

# Database backend: sqlite | postgres | mysql
DB_TYPE=sqlite

# Database credentials (always required)
DB_PASSWORD=replace-db-password

# SQLite configuration (required when DB_TYPE=sqlite)
DB_FILE=./voletu_server.db

# Postgres / MySQL configuration (required when DB_TYPE=postgres or mysql)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=voletu
DB_USER=voletu

# Logging
LOG_FILTER=info,voletu_core=debug,voletu_server=debug
LOG_FILE=./logs/voletu-server.log
