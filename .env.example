# Server configuration (packages/server)

# Database Type: sqlite or postgres
DB_TYPE=sqlite

# SQLite Configuration (when DB_TYPE=sqlite)
DB_PATH=./voletu_server.db

# PostgreSQL Configuration (when DB_TYPE=postgres)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=voletu
# DB_USER=postgres
# DB_PASSWORD=your_password

# Server host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# Server port
PORT=3000

# Frontend configuration (packages/frontend)
# API URL for web deployment (leave empty to use localhost:3000)
VITE_API_URL=http://localhost:3000
